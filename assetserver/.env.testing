# .env.testing — Drop-in preset for ComfyUI-free testing
# =====================================================================
#
# PURPOSE: Overrides ALL generation modes to "placeholder" so the full API
# works with zero external dependencies — no GPU, no ComfyUI, no models.
# All endpoints return procedural coloured placeholders.
#
# USAGE:
#   cp .env.testing .env          # Activate testing mode
#   rm .env                       # Revert to config.yaml defaults (ComfyUI mode)
#
# FOR PRODUCTION: Do NOT use this file. Create a minimal .env with only
# the ComfyUI URL override:
#   echo 'COMFYUI__BASE_URL=http://your-server:8188' > .env
#
# All available settings are documented in:
#   - config.yaml (version-controlled defaults & structure)
#   - .env.example (reference for every overrideable variable)
#   - docs/architecture.md §9 (config layering documentation)
#
# Mode reference:
#   comfyui     → Full AI generation via ComfyUI server
#   static      → Pre-made PNGs from static_tiles/, fallback to placeholder
#   placeholder → Always procedural coloured placeholders (zero deps)
# =====================================================================

# ---- All asset families in static/placeholder mode (no ComfyUI) ------
GENERATION__MODES__BACKGROUND_TILE=placeholder
GENERATION__MODES__STRUCTURE=placeholder
GENERATION__MODES__OBJECT=placeholder
GENERATION__MODES__TERRAIN=placeholder
GENERATION__MODES__NATURE_OBJECT=placeholder
GENERATION__MODES__CHARACTER_SPRITE=placeholder
GENERATION__MODES__UNIT=placeholder
GENERATION__MODES__STORY=placeholder
GENERATION__MODES__SPLASH=placeholder
GENERATION__MODES__LEADER=placeholder
GENERATION__DEFAULT_MODE=placeholder
