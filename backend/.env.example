# =============================================================================
# StrategAI Backend — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# The .env file is loaded automatically by python-dotenv at startup
# (called in app/engine/openai_goals.py). Place this file in the backend/
# directory — the same directory from which you run uvicorn.
# =============================================================================

# ---------------------------------------------------------------------------
# OpenAI API Key — REQUIRED
# ---------------------------------------------------------------------------
# Used by:
#   - AI civilization goal sources (LLM-driven strategic decisions)
#   - Audio narration endpoint (text-to-speech intro)
#
# Without this key:
#   - AI civs fall back to RandomGoalSource (deterministic stub)
#   - The /audio/intro endpoint returns HTTP 503
#   - Human players can still play normally
#
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ---------------------------------------------------------------------------
# OpenAI TTS Model — Optional
# ---------------------------------------------------------------------------
# Model used for the intro narration voiceover (/audio/intro endpoint).
# Must be a TTS-capable OpenAI model.
# Default: gpt-4o-mini-tts
# OPENAI_TTS_MODEL=gpt-4o-mini-tts

# ---------------------------------------------------------------------------
# OpenAI TTS Voice — Optional
# ---------------------------------------------------------------------------
# Voice preset for the intro narration.
# Supported OpenAI TTS voices: alloy, ash, cedar, coral, echo, fable, onyx,
# nova, sage, shimmer.
# Default: cedar
# OPENAI_TTS_VOICE=cedar

# =============================================================================
# NOTE: The following parameters are HARDCODED in the source code and cannot
# be changed via environment variables:
#
#   LLM model (for AI civs):    gpt-5.4-mini   (openai_goals.py line 472)
#   LLM temperature:            0.7            (openai_goals.py line 474)
#   Rolling memory window:      8 turns        (openai_goals.py line 472)
#   Max remembered items:       32             (openai_goals.py line 471)
#   Starting gold:              20             (game_factory.py line 103)
#   Default map radius:         8              (game_factory.py line 143)
#   Default number of civs:     4              (game_factory.py line 145)
#
# To change these, edit the source files directly:
#   - LLM settings:  app/engine/openai_goals.py  (OpenAIGoalSource.__init__)
#   - Game defaults: app/api/game_factory.py     (new_game)
# =============================================================================
