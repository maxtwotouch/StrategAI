{
  "_comment": "Flux2 Klein img2img workflow for leader action scenes. Uses LoadImage for reference, VAEEncode, denoise=0.60 for action variety.",
  "1": {
    "inputs": {
      "unet_name": "flux-2-klein-4b-fp8.safetensors"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Load UNET"}
  },
  "2": {
    "inputs": {
      "text": "PLACEHOLDER_POSITIVE",
      "clip": ["8", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Positive)"}
  },
  "4": {
    "inputs": {
      "image": "ref_placeholder.png",
      "upload": "image"
    },
    "class_type": "LoadImage",
    "_meta": {"title": "Load Reference Image"}
  },
  "5": {
    "inputs": {
      "pixels": ["4", 0],
      "vae": ["9", 2]
    },
    "class_type": "VAEEncode",
    "_meta": {"title": "VAE Encode"}
  },
  "6": {
    "inputs": {
      "noise": ["14", 0],
      "guider": ["11", 0],
      "sampler": ["13", 0],
      "sigmas": ["12", 0],
      "latent_image": ["5", 0]
    },
    "class_type": "SamplerCustomAdvanced",
    "_meta": {"title": "Sampler Custom Advanced"}
  },
  "7": {
    "inputs": {
      "samples": ["6", 0],
      "vae": ["9", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "8": {
    "inputs": {
      "filename_prefix": "leader_action",
      "images": ["7", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  },
  "9": {
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "flux2"
    },
    "class_type": "CLIPLoader",
    "_meta": {"title": "Load CLIP"}
  },
  "10": {
    "inputs": {
      "vae_name": "flux2-vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"}
  },
  "11": {
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["2", 0],
      "cfg": 3.5
    },
    "class_type": "CFGGuider",
    "_meta": {"title": "CFG Guider"}
  },
  "12": {
    "inputs": {
      "model": ["1", 0],
      "steps": 4,
      "denoise": 0.60
    },
    "class_type": "Flux2Scheduler",
    "_meta": {"title": "Flux2 Scheduler"}
  },
  "13": {
    "inputs": {
      "sampler_name": "euler"
    },
    "class_type": "KSamplerSelect",
    "_meta": {"title": "KSampler Select"}
  },
  "14": {
    "inputs": {
      "noise_seed": 0
    },
    "class_type": "RandomNoise",
    "_meta": {"title": "Random Noise"}
  }
}
