{
  "_comment": "Flux2 Klein txt2img workflow for top-down medieval pixel-art game assets (structures, objects, terrain, units). Uses UNETLoader, CLIPLoader, VAELoader; Flux2 has no negative prompt. CFGGuider + Flux2Scheduler + KSamplerSelect + SamplerCustomAdvanced. Resolution: 512x512.",
  "1": {
    "inputs": {
      "unet_name": "flux-2-klein-4b-fp8.safetensors"
    },
    "class_type": "UNETLoader",
    "_meta": {"title": "Load UNET"}
  },
  "2": {
    "inputs": {
      "text": "PLACEHOLDER_POSITIVE",
      "clip": ["8", 0]
    },
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "CLIP Text Encode (Positive)"}
  },
  "4": {
    "inputs": {
      "width": 512,
      "height": 512,
      "batch_size": 1
    },
    "class_type": "EmptyFlux2LatentImage",
    "_meta": {"title": "Empty Flux2 Latent Image"}
  },
  "5": {
    "inputs": {
      "noise": ["4", 0],
      "guider": ["10", 0],
      "sampler": ["12", 0],
      "sigmas": ["11", 0],
      "latent_image": ["4", 0]
    },
    "class_type": "SamplerCustomAdvanced",
    "_meta": {"title": "Sampler Custom Advanced"}
  },
  "6": {
    "inputs": {
      "samples": ["5", 0],
      "vae": ["9", 2]
    },
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"}
  },
  "7": {
    "inputs": {
      "filename_prefix": "tile_asset",
      "images": ["6", 0]
    },
    "class_type": "SaveImage",
    "_meta": {"title": "Save Image"}
  },
  "8": {
    "inputs": {
      "clip_name": "qwen_3_4b.safetensors",
      "type": "flux2"
    },
    "class_type": "CLIPLoader",
    "_meta": {"title": "Load CLIP"}
  },
  "9": {
    "inputs": {
      "vae_name": "flux2-vae.safetensors"
    },
    "class_type": "VAELoader",
    "_meta": {"title": "Load VAE"}
  },
  "10": {
    "inputs": {
      "model": ["1", 0],
      "conditioning": ["2", 0],
      "cfg": 3.5
    },
    "class_type": "CFGGuider",
    "_meta": {"title": "CFG Guider"}
  },
  "11": {
    "inputs": {
      "model": ["1", 0],
      "steps": 4,
      "denoise": 1.0
    },
    "class_type": "Flux2Scheduler",
    "_meta": {"title": "Flux2 Scheduler"}
  },
  "12": {
    "inputs": {
      "sampler_name": "euler"
    },
    "class_type": "KSamplerSelect",
    "_meta": {"title": "KSampler Select"}
  }
}

