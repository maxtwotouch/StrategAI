# IMPORTANT: This file lives in the *frontend* directory (Next.js root), NOT
# in the repo root — Next.js reads .env files relative to its own root. Vars
# referenced by browser code must be prefixed `NEXT_PUBLIC_` to be exposed.
# Copy to `.env.local` (gitignored) and fill in real values.

# Game backend (FastAPI) — turn resolution, actions, game state.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Medieval Pixel Art asset service. When set, the game resolves generated
# terrain, structures, units, elevation, and leader portraits on game start.
# Leave unset to render with built-in colors and initials (no asset requests).
NEXT_PUBLIC_ASSET_API_URL=
