# Game backend (FastAPI) — turn resolution, actions, game state.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Medieval Pixel Art asset service. When set, the game resolves generated
# terrain tiles + leader portraits on game start. Leave unset to render with
# the built-in colors and initials (no asset requests are made).
# Point this at wherever the asset server is hosted, e.g.:
# NEXT_PUBLIC_ASSET_API_URL=http://localhost:8001
NEXT_PUBLIC_ASSET_API_URL=
