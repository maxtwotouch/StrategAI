# Medieval Pixel Art Image Service - Environment Configuration
# =====================================================================
# Copy to .env and adjust for your deployment.
# Use __ (double underscore) as the nesting delimiter for nested keys.
# Example: COMFYUI__BASE_URL overrides comfyui.base_url in config.yaml.
# =====================================================================

# ---- Server ----------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000

# ---- ComfyUI connection ----------------------------------------------
# COMFYUI__BASE_URL=http://127.0.0.1:8188
# COMFYUI__TIMEOUT=300

# ---- Generation modes (per asset family) -----------------------------
# Valid: "comfyui" | "static" | "placeholder" | "random"
#
#   comfyui     → Full AI generation via ComfyUI server
#   static      → Pre-made PNGs from static_tiles/, fallback to placeholder
#   placeholder → Always procedural coloured placeholders (zero deps)
#   random      → Coin-flip between comfyui and static each request
#
# GENERATION__MODES__BACKGROUND_TILE=comfyui
# GENERATION__MODES__STRUCTURE=comfyui
# GENERATION__MODES__NATURE_OBJECT=comfyui
# GENERATION__MODES__CHARACTER_SPRITE=comfyui
# GENERATION__MODES__STORY=comfyui
# GENERATION__MODES__SPLASH=comfyui
# GENERATION__MODES__LEADER=comfyui
# GENERATION__DEFAULT_MODE=comfyui
# GENERATION__RANDOM_PROBABILITY=0.5

# ---- Splash defaults -------------------------------------------------
# SPLASH__WIDTH=256
# SPLASH__HEIGHT=256

# ---- Leader pipeline -------------------------------------------------
# LEADER__NEGATIVE_PROMPT=blurry, low quality, distorted, ugly, deformed face, bad hands, missing fingers, text, watermark, signature, logo, cartoon, 3D render, photograph, selfie, modern clothing, jeans, t-shirt, plastic, oversaturated colors, bad anatomy, extra limbs, cloned face, disfigured, jpeg artifacts
