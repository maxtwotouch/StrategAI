# =============================================================================
# .env.example — Deployment-specific overrides for Medieval Pixel Art Service
# =============================================================================
#
# This file documents ALL available environment variable overrides for reference.
# In practice, your .env should be MINIMAL — only values that differ from the
# config.yaml defaults.
#
# RULE: If a value in .env equals the config.yaml default, it doesn't belong here.
#
# QUICK START:
#   - Local dev with ComfyUI:   echo 'COMFYUI__BASE_URL=http://your-server:8188' > .env
#   - ComfyUI-free testing:     cp .env.testing .env
#   - Production:               set COMFYUI__BASE_URL + MODE=production + API key
#
# All defaults live in config.yaml (version-controlled, source of truth).
# See docs/architecture.md §9 for the full config layering documentation.
#
# Naming convention: pydantic-settings uses ``__`` (double underscore) as the
# nested delimiter.  Top-level fields use the field name directly.
#   Example:  COMFYUI__BASE_URL  →  settings.comfyui.base_url
#             SERVER__CORS_ORIGINS  →  settings.server.cors_origins
#             DATABASE_URL  →  settings.database_url
#
# For dict fields like generation.modes, you can set individual keys:
#   GENERATION__MODES__STRUCTURE=static
# Or override the whole dict as a JSON string:
#   GENERATION__MODES={"structure":"static","object":"placeholder",...}
#
# Load order (later wins): defaults → env vars → config.yaml → .env → secrets
# =============================================================================


# ---------------------------------------------------------------------------
#  Deployment mode
# ---------------------------------------------------------------------------

# Set to "production" to enable stricter startup safety checks
# (CORS must be explicit, schema mismatches are fatal, etc.).
# MODE=development


# ---------------------------------------------------------------------------
#  Network / bind
# ---------------------------------------------------------------------------

# SERVER__HOST=0.0.0.0
# SERVER__PORT=8000


# ---------------------------------------------------------------------------
#  Database
# ---------------------------------------------------------------------------

# SQLite (default — auto-created at project root as tilemap.db):
# DATABASE_URL=
#
# This project uses SQLite exclusively.  WAL journal mode and busy_timeout
# pragmas are applied automatically for safe concurrent access.
#
# Escape hatch: set to "true"/"1"/"yes" to drop & recreate all tables on
# next startup.  BLOCKED in PRODUCTION mode.
# DATABASE_RESET=false


# ---------------------------------------------------------------------------
#  ComfyUI inference server(s)
# ---------------------------------------------------------------------------

# Single-node (backward-compatible):
# COMFYUI__BASE_URL=http://127.0.0.1:8188
# COMFYUI__TIMEOUT=300
# COMFYUI__HEALTH_CHECK_INTERVAL=30
# COMFYUI__MAX_RETRIES=3

# Multi-node (JSON array of URLs — overrides base_url):
# COMFYUI__NODES=["http://gpu1:8188","http://gpu2:8188","http://gpu3:8188"]

# Model warmup — preload DiT weights into GPU VRAM at startup.
# Disable to skip (e.g., for multi-tenant ComfyUI with limited VRAM).
# COMFYUI__WARMUP_ENABLED=true
# COMFYUI__WARMUP_TIMEOUT=120
# COMFYUI__WARMUP_WORKFLOW=background_tile


# ---------------------------------------------------------------------------
#  Paths (all relative to project root)
# ---------------------------------------------------------------------------

# PATHS__OUTPUT_DIR=generated_assets
# PATHS__SPLASH_DIR=splash_assets
# PATHS__STATIC_TILES_DIR=static_tiles
# PATHS__LEADER_REFERENCE_DIR=leader_references

# Optional: absolute path to a .ttf/.ttc font for placeholder image labels.
# Leave empty to auto-detect from common system locations.
# PATHS__FONT_PATH=


# ---------------------------------------------------------------------------
#  HTTP server
# ---------------------------------------------------------------------------

# CORS allowed origins (JSON array).  The default allows local development.
# Set to your frontend domain(s) in production.  Using ["*"] is a security risk.
# SERVER__CORS_ORIGINS=["http://localhost:3000"]

# Max request body size in megabytes (1–100):
# SERVER__MAX_REQUEST_BODY_MB=10

# URL prefix for serving generated assets:
# SERVER__ASSETS_URL_PREFIX=/assets

# In-memory LRU image cache limits:
# SERVER__CACHE_MAX_ENTRIES=1000
# SERVER__CACHE_MAX_MB=500

# Optional static API key.  When set, all requests must include the header
# ``X-API-Key: <key>``.  Leave empty to disable authentication.
# SERVER__API_KEY=

# Bind address and port for the HTTP server:
# SERVER__HOST=0.0.0.0
# SERVER__PORT=8000


# ---------------------------------------------------------------------------
#  Rate limiting (token-bucket, global — not per-IP)
# ---------------------------------------------------------------------------

# Max POST (generation) requests per second globally:
# RATE_LIMIT__POST_RPS=2.0

# Max GET (read) requests per second globally:
# RATE_LIMIT__GET_RPS=50.0

# Max burst size for POST endpoints before throttling:
# RATE_LIMIT__BURST_SIZE=5

# Set to false to disable rate limiting entirely (e.g., in tests):
# RATE_LIMIT__ENABLED=true


# ---------------------------------------------------------------------------
#  Generation mode routing (per asset family)
# ---------------------------------------------------------------------------
#
# Valid per-family values: "comfyui" | "static" | "placeholder"
#
#   comfyui     → Full AI generation via ComfyUI server
#   static      → Pre-made PNGs from static_tiles/, fallback to placeholder
#   placeholder → Always procedural coloured placeholders (zero deps)
#
# Families: structure, object, terrain, background_tile, unit, leader,
#           character_sprite, nature_object, story, splash
#
# NOTE: These all default to "comfyui" in config.yaml. Only override them
# if a specific family should use a different mode in your deployment.
# For ComfyUI-free testing, use .env.testing instead of uncommenting these.

# GENERATION__MODES__STRUCTURE=comfyui
# GENERATION__MODES__OBJECT=comfyui
# GENERATION__MODES__TERRAIN=comfyui
# GENERATION__MODES__BACKGROUND_TILE=comfyui
# GENERATION__MODES__UNIT=comfyui
# GENERATION__MODES__LEADER=comfyui
# GENERATION__MODES__CHARACTER_SPRITE=comfyui
# GENERATION__MODES__NATURE_OBJECT=comfyui
# GENERATION__MODES__STORY=comfyui
# GENERATION__MODES__SPLASH=comfyui
# GENERATION__DEFAULT_MODE=comfyui

# ---- Database --------------------------------------------------------
# DATABASE_URL=sqlite:///tilemap.db

# ---- Paths (additional) ----------------------------------------------
# PATHS__FONT_PATH=/usr/share/fonts/truetype/dejavu/DejaVuSans.ttf

# ---- Deployment mode -------------------------------------------------
# MODE=development   # or production
