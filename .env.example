# Medieval Pixel Art Image Service - Environment Configuration
# =====================================================================
# Copy to .env and adjust for your deployment.
# Use __ (double underscore) as the nesting delimiter for nested keys.
# Example: COMFYUI__BASE_URL overrides comfyui.base_url in config.yaml.
# =====================================================================

# ---- Server ----------------------------------------------------------
# HOST=0.0.0.0
# PORT=8000

# ---- ComfyUI connection ----------------------------------------------
# Single-node:
# COMFYUI__BASE_URL=http://127.0.0.1:8188
# COMFYUI__TIMEOUT=300
# COMFYUI__HEALTH_CHECK_INTERVAL=30
# COMFYUI__MAX_RETRIES=3

# Multi-node (JSON array of URLs — overrides base_url):
# COMFYUI__NODES=["http://gpu1:8188","http://gpu2:8188","http://gpu3:8188"]

# ---- Paths (relative to project root) ---------------------------------
# PATHS__OUTPUT_DIR=generated_assets
# PATHS__SPLASH_DIR=splash_assets
# PATHS__STATIC_TILES_DIR=static_tiles
# PATHS__LEADER_REFERENCE_DIR=leader_references

# ---- Generation modes (per asset family) -----------------------------
# Valid: "comfyui" | "static" | "placeholder"
#
#   comfyui     → Full AI generation via ComfyUI server
#   static      → Pre-made PNGs from static_tiles/, fallback to placeholder
#   placeholder → Always procedural coloured placeholders (zero deps)
#
# GENERATION__MODES__STRUCTURE=comfyui
# GENERATION__MODES__OBJECT=comfyui
# GENERATION__MODES__TERRAIN=comfyui
# GENERATION__MODES__BACKGROUND_TILE=comfyui
# GENERATION__MODES__UNIT=comfyui
# GENERATION__MODES__LEADER=comfyui
# GENERATION__DEFAULT_MODE=comfyui

# ---- Server security -------------------------------------------------
# SERVER__CORS_ORIGINS=["https://mygame.com"]
# SERVER__MAX_REQUEST_BODY_MB=10
# SERVER__ASSETS_URL_PREFIX=/assets
